# ══════════════════════════════════════════════════════════
#  Casa Julio — Variables de entorno
#  Copia este archivo como .env.local y rellena los valores
# ══════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────
# Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_REF.supabase.co

# Dashboard → Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXX

# ── Resend (emails de confirmación de reserva) ─────────────
# https://resend.com/api-keys
# El dominio remitente debe estar verificado en Resend
# En producción: reservas@tudominio.com
# En desarrollo puedes usar el sandbox de Resend
RESEND_API_KEY=re_XXXXXXXXXXXX

# ── (Opcional) Solo para scripts de setup ──────────────────
# Dashboard → Settings → API → service_role key
# NO añadir a Vercel — solo se usa en scripts/create-admin-user.mjs
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
